<UserControl x:Class="MairaSimHub.WindPlugin.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             xmlns:ui="clr-namespace:SimHub.Plugins.UI;assembly=SimHub.Plugins"
             mc:Ignorable="d">

    <!-- DataContext is set to Plugin.Settings in code-behind.
         All Value / IsChecked bindings are TwoWay so changes write back immediately. -->

    <ScrollViewer>
        <StackPanel>

            <!-- ================================================================
                 CONNECTION
                 ================================================================ -->
            <styles:SHSection Title="CONNECTION">
                <StackPanel>

                    <styles:SHToggleCheckbox IsChecked="{Binding WindEnabled, Mode=TwoWay}">
                        Enable MAIRA Typhoon Wind plugin
                    </styles:SHToggleCheckbox>

                    <styles:SHSectionSeparator />

                    <styles:SHToggleCheckbox IsChecked="{Binding AutoConnect, Mode=TwoWay}">
                        Auto-connect to device on SimHub startup
                    </styles:SHToggleCheckbox>

                    <styles:SHSectionSeparator />

                    <StackPanel Orientation="Horizontal">
                        <styles:SHButtonPrimary Click="ConnectButton_Click"
                                                Margin="0,0,8,0">
                            Connect
                        </styles:SHButtonPrimary>
                        <styles:SHButtonSecondary Click="DisconnectButton_Click">
                            Disconnect
                        </styles:SHButtonSecondary>
                    </StackPanel>

                    <styles:SHSectionSeparator />

                    <TextBlock x:Name="ConnectionStatusText"
                               FontStyle="Italic"
                               Margin="0,0,0,4" />

                </StackPanel>
            </styles:SHSection>

            <!-- ================================================================
                 GENERAL SETTINGS
                 ================================================================ -->
            <styles:SHSection Title="GENERAL SETTINGS">
                <StackPanel>

                    <!-- Master power: 0 = fans off, 100 = full output -->
                    <ui:TitledSlider Title="Master wind power  (%)"
                                     Minimum="0" Maximum="100"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindMasterWindPower, Mode=TwoWay}" />

                    <styles:SHSectionSeparator />

                    <!-- Minimum speed: fans run at this speed's mapped power even when slower -->
                    <ui:TitledSlider Title="Minimum speed floor  (km/h, 0 = disabled)"
                                     Minimum="0" Maximum="100"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindMinimumSpeed, Mode=TwoWay}" />

                    <styles:SHSectionSeparator />

                    <!-- Curving: how strongly turning biases the left/right fan split -->
                    <!-- At 100 %, ~30 deg/s yaw rate fully biases wind to one side    -->
                    <ui:TitledSlider Title="Wind curving  (%, 0 = no split, 100 = full)"
                                     Minimum="0" Maximum="100"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindCurving, Mode=TwoWay}" />

                </StackPanel>
            </styles:SHSection>

            <!-- ================================================================
                 FAN POWER CURVE
                 10 speed / fan-power breakpoints.  Speeds in km/h, powers in %.
                 Uses Catmull-Rom / Hermite interpolation between points.
                 Keep speeds in ascending order.
                 ================================================================ -->
            <styles:SHSection Title="FAN POWER CURVE — POINT 1">
                <StackPanel>
                    <ui:TitledSlider Title="Speed  (km/h)"
                                     Minimum="0" Maximum="360"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindSpeed1, Mode=TwoWay}" />
                    <styles:SHSectionSeparator />
                    <ui:TitledSlider Title="Fan power  (%)"
                                     Minimum="0" Maximum="100"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindFanPower1, Mode=TwoWay}" />
                </StackPanel>
            </styles:SHSection>

            <styles:SHSection Title="FAN POWER CURVE — POINT 2">
                <StackPanel>
                    <ui:TitledSlider Title="Speed  (km/h)"
                                     Minimum="0" Maximum="360"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindSpeed2, Mode=TwoWay}" />
                    <styles:SHSectionSeparator />
                    <ui:TitledSlider Title="Fan power  (%)"
                                     Minimum="0" Maximum="100"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindFanPower2, Mode=TwoWay}" />
                </StackPanel>
            </styles:SHSection>

            <styles:SHSection Title="FAN POWER CURVE — POINT 3">
                <StackPanel>
                    <ui:TitledSlider Title="Speed  (km/h)"
                                     Minimum="0" Maximum="360"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindSpeed3, Mode=TwoWay}" />
                    <styles:SHSectionSeparator />
                    <ui:TitledSlider Title="Fan power  (%)"
                                     Minimum="0" Maximum="100"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindFanPower3, Mode=TwoWay}" />
                </StackPanel>
            </styles:SHSection>

            <styles:SHSection Title="FAN POWER CURVE — POINT 4">
