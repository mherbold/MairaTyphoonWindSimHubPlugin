                <StackPanel>
                    <ui:TitledSlider Title="Speed  (km/h)"
                                     Minimum="0" Maximum="360"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindSpeed5, Mode=TwoWay}" />
                    <styles:SHSectionSeparator />
                    <ui:TitledSlider Title="Fan power  (%)"
                                     Minimum="0" Maximum="100"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindFanPower5, Mode=TwoWay}" />
                </StackPanel>
            </styles:SHSection>

            <styles:SHSection Title="FAN POWER CURVE — POINT 6">
                <StackPanel>
                    <ui:TitledSlider Title="Speed  (km/h)"
                                     Minimum="0" Maximum="360"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindSpeed6, Mode=TwoWay}" />
                    <styles:SHSectionSeparator />
                    <ui:TitledSlider Title="Fan power  (%)"
                                     Minimum="0" Maximum="100"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindFanPower6, Mode=TwoWay}" />
                </StackPanel>
            </styles:SHSection>

            <styles:SHSection Title="FAN POWER CURVE — POINT 7">
                <StackPanel>
                    <ui:TitledSlider Title="Speed  (km/h)"
                                     Minimum="0" Maximum="360"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindSpeed7, Mode=TwoWay}" />
                    <styles:SHSectionSeparator />
                    <ui:TitledSlider Title="Fan power  (%)"
                                     Minimum="0" Maximum="100"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindFanPower7, Mode=TwoWay}" />
                </StackPanel>
            </styles:SHSection>

            <styles:SHSection Title="FAN POWER CURVE — POINT 8">
                <StackPanel>
                    <ui:TitledSlider Title="Speed  (km/h)"
                                     Minimum="0" Maximum="360"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindSpeed8, Mode=TwoWay}" />
                    <styles:SHSectionSeparator />
                    <ui:TitledSlider Title="Fan power  (%)"
                                     Minimum="0" Maximum="100"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindFanPower8, Mode=TwoWay}" />
                </StackPanel>
            </styles:SHSection>

            <styles:SHSection Title="FAN POWER CURVE — POINT 9">
                <StackPanel>
                    <ui:TitledSlider Title="Speed  (km/h)"
                                     Minimum="0" Maximum="360"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindSpeed9, Mode=TwoWay}" />
                    <styles:SHSectionSeparator />
                    <ui:TitledSlider Title="Fan power  (%)"
                                     Minimum="0" Maximum="100"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindFanPower9, Mode=TwoWay}" />
                </StackPanel>
            </styles:SHSection>

            <styles:SHSection Title="FAN POWER CURVE — POINT 10">
                <StackPanel>
                    <ui:TitledSlider Title="Speed  (km/h)"
                                     Minimum="0" Maximum="360"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindSpeed10, Mode=TwoWay}" />
                    <styles:SHSectionSeparator />
                    <ui:TitledSlider Title="Fan power  (%)"
                                     Minimum="0" Maximum="100"
                                     TickFrequency="1" IsSnapToTickEnabled="True"
                                     InputInterval="1" StringFormat="0"
                                     Value="{Binding WindFanPower10, Mode=TwoWay}" />
                </StackPanel>
            </styles:SHSection>

            <!-- ================================================================
                 FAN TEST
                 Runs left or right fan at 100 % to verify hardware is working.
                 ================================================================ -->
            <styles:SHSection Title="FAN TEST">
                <StackPanel>

                    <TextBlock Text="Run a fan at 100 % power to verify it is working."
                               FontStyle="Italic"
                               Margin="0,0,0,8" />

                    <StackPanel Orientation="Horizontal">
                        <styles:SHButtonPrimary Click="TestLeftButton_Click"
                                                Margin="0,0,8,0">
                            Test Left Fan
                        </styles:SHButtonPrimary>
                        <styles:SHButtonPrimary Click="TestRightButton_Click"
                                                Margin="0,0,8,0">
                            Test Right Fan
                        </styles:SHButtonPrimary>
                        <styles:SHButtonSecondary Click="StopTestButton_Click">
                            Stop Test
                        </styles:SHButtonSecondary>
                    </StackPanel>

                    <styles:SHSectionSeparator />

                    <TextBlock x:Name="TestStatusText"
                               FontStyle="Italic"
                               Margin="0,0,0,4" />

                </StackPanel>
            </styles:SHSection>

        </StackPanel>
    </ScrollViewer>
</UserControl>
